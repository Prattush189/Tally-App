# Copy this file to .env and fill in the real values. .env is gitignored.
#
# Supabase — find these at https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://vqusztwxrjokjgkiebem.supabase.co
SUPABASE_ANON_KEY=

# Local sync shared secret. Must match the LOCAL_SYNC_TOKEN set on the Edge
# Function (supabase secrets set LOCAL_SYNC_TOKEN=...).
LOCAL_SYNC_TOKEN=

# Optional: set HEADED=1 to watch the browser drive the portal login. Useful
# when the portal's DOM changes and the "click TallyPrime" step stops working.
# HEADED=1

# Optional: override the tenant slug if you sync multiple companies.
# TENANT_KEY=default
