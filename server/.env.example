# Required in production. Generate a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# API port
PORT=3001

# Optional CORS whitelist — comma-separated origins.
# Leave unset to allow all (development only).
# CORS_ORIGIN=https://your-username.github.io,https://your-domain.com

# Tally Prime XML server (optional — mock data is used when unreachable)
TALLY_HOST=127.0.0.1
TALLY_PORT=9000
# TALLY_USER=
# TALLY_PASS=

# Set to "production" for production deployments.
NODE_ENV=development
